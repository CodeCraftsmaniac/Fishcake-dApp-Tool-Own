# Fishcake Backend Environment Configuration
# Copy this file to .env and update values for your deployment
# DO NOT COMMIT .env - it contains secrets!

# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URLs (comma-separated, for CORS)
# Add all your Vercel deployment URLs here
FRONTEND_URLS=https://fishcake-dapp.vercel.app,https://your-app-git-main.vercel.app,http://localhost:3000

# ============================================
# SUPABASE DATABASE (PRIMARY)
# ============================================
# Get these from your Supabase project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# RPC Configuration (Polygon Mainnet)
# ============================================
# Free public RPCs (fallback)
RPC_PUBLICNODE=https://polygon-bor-rpc.publicnode.com
RPC_ANKR=https://rpc.ankr.com/polygon
RPC_LLAMARPC=https://polygon.llamarpc.com
RPC_BLOCKPI=https://polygon.blockpi.network/v1/rpc/public

# Optional: Add your private RPC keys for better reliability
# RPC_ALCHEMY=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
# RPC_DRPC=https://lb.drpc.org/ogrpc?network=polygon&dkey=YOUR_KEY_HERE

# ============================================
# JWT Secret (MUST be 32+ chars, ideally 64+)
# ============================================
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_IN_PRODUCTION

# ============================================
# Mining Scheduler
# ============================================
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=300000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
