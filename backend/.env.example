# Fishcake Backend Environment Configuration
# Production deployment on Railway

# Server Configuration
PORT=8080
NODE_ENV=production

# Frontend URLs (comma-separated, for CORS)
FRONTEND_URLS=https://fishcake-dapp.vercel.app,https://fishcake-dapp-git-main-adamjeeans-projects.vercel.app,https://fishcake-dapp-adamjeeans-projects.vercel.app

# Database (Railway persistent storage)
DATABASE_PATH=/app/data/fishcake.db
MINING_DB_PATH=/app/data/mining.db

# RPC Configuration (Polygon Mainnet)
RPC_ALCHEMY=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
RPC_DRPC=https://lb.drpc.org/ogrpc?network=polygon&dkey=YOUR_KEY_HERE
RPC_PUBLICNODE=https://polygon-bor-rpc.publicnode.com
RPC_ANKR=https://rpc.ankr.com/polygon
RPC_LLAMARPC=https://polygon.llamarpc.com
RPC_BLOCKPI=https://polygon.blockpi.network/v1/rpc/public

# JWT Secret (generate a strong random string for production)
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_IN_PRODUCTION

# Mining Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=300000

# Logging
LOG_LEVEL=info
