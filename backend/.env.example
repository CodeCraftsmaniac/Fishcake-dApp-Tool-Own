# Fishcake Backend Environment Configuration
# Copy this file to .env and update values

# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URLs (comma-separated, for CORS)
FRONTEND_URLS=https://fishcake-dapp.vercel.app,http://localhost:3000

# Database
DATABASE_PATH=./data/fishcake.db

# RPC Configuration (primary endpoints)
RPC_ALCHEMY=https://polygon-mainnet.g.alchemy.com/v2/LkNoRUIu8n117O626DO9M
RPC_DRPC=https://lb.drpc.org/ogrpc?network=polygon&dkey=Ai-2uYNWu0OmkBvx0BdHgkDK29YkMEwR8aE0Grar0DFx
RPC_PUBLICNODE=https://polygon-bor-rpc.publicnode.com
RPC_ANKR=https://rpc.ankr.com/polygon

# JWT Secret (generate a strong random string for production)
JWT_SECRET=fishcake-backend-jwt-secret-change-this-in-production

# Mining Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=300000

# Logging
LOG_LEVEL=info
