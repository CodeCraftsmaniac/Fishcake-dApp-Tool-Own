{
  "name": "@fishcake/backend",
  "version": "1.0.0",
  "description": "Fishcake Backend - Shared business logic for CLI and Web applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./blockchain": {
      "import": "./dist/blockchain/index.js",
      "types": "./dist/blockchain/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.js",
      "types": "./dist/wallet/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "start": "node dist/serverSupabase.js",
    "start:sqlite": "node dist/server.js",
    "dev": "tsx watch src/serverSupabase.ts",
    "dev:sqlite": "tsx watch src/server.ts",
    "server": "node dist/serverSupabase.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:blockchain": "vitest run tests/blockchain-mock.test.ts",
    "e2e": "tsx scripts/e2e-test.ts",
    "db:push": "tsx scripts/push-supabase-schema.ts",
    "db:test": "tsx scripts/test-supabase-db.ts",
    "migrate": "tsx scripts/migrate-to-supabase.ts",
    "backup": "tsx scripts/backup-sqlite.ts",
    "backup:restore": "tsx scripts/backup-sqlite.ts --restore",
    "backup:list": "tsx scripts/backup-sqlite.ts --list",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@scure/bip32": "^1.3.2",
    "@supabase/supabase-js": "^2.101.1",
    "better-sqlite3": "^12.8.0",
    "bip39": "^3.1.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
